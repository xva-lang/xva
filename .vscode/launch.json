{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug executable 'xva'",
      "cargo": {
        "args": ["build", "--bin=xva", "--package=xva"],
        "filter": {
          "name": "xva",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests in executable 'xva'",
      "cargo": {
        "args": ["test", "--no-run", "--bin=xva", "--package=xva"],
        "filter": {
          "name": "xva",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  ]
}
